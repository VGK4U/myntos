<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Categories - RVZ Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
      min-height: 100vh;
      padding: 2rem 0;
    }
    .main-card {
      background: white;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      padding: 2rem;
    }
    .category-table {
      margin-top: 1.5rem;
    }
    .category-row {
      border-bottom: 1px solid #e0e0e0;
      padding: 1rem 0;
      transition: background 0.2s;
    }
    .category-row:hover {
      background: #f8f9fa;
    }
    .edit-mode {
      background: #fff3cd !important;
    }
    .action-buttons {
      white-space: nowrap;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="main-card">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><img src="/public/vgk4u-logo-100.png" srcset="/public/vgk4u-logo-100.png 2x" alt="VGK4U" style="height:48px;width:48px;background:#fff;border-radius:5px;padding:2px 6px;margin-right:8px;vertical-align:middle;object-fit:contain;"><i class="fas fa-tags me-2"></i>Manage Announcement Categories</h2>
        <button class="btn btn-primary" data-bs-toggle="offcanvas" data-bs-target="#addCategoryOffcanvas">
          <i class="fas fa-plus me-1"></i>Add Category
        </button>
      </div>

      <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        Categories help organize feedback submissions and announcements. Users will select a category when submitting announcements.
      </div>

      <!-- Categories Table -->
      <div id="categoriesTable"></div>
    </div>
  </div>

  <!-- Add Category Offcanvas -->
  <div class="offcanvas offcanvas-end" tabindex="-1" id="addCategoryOffcanvas">
    <div class="offcanvas-header">
      <h5 class="offcanvas-title">Add New Category</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
      <form id="addCategoryForm">
        <div class="mb-3">
          <label class="form-label fw-bold">Category Name*</label>
          <input type="text" class="form-control" id="newCategoryName" required maxlength="100">
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Description</label>
          <textarea class="form-control" id="newCategoryDesc" rows="3" maxlength="500"></textarea>
          <small class="text-muted">Optional description for this category</small>
        </div>
        <button type="submit" class="btn btn-primary w-100">
          <i class="fas fa-save me-1"></i>Save Category
        </button>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Inject sessionToken into sessionStorage for module access
    if (typeof sessionToken !== 'undefined') {
      sessionStorage.setItem('session_token', sessionToken);
    }
  </script>
  <script type="module">
    import { feedbackApi, showToast, showSpinner, showEmptyState, showConfirmModal } from '/shared/feedback/feedbackShared.js';

    let categories = [];

    // Load categories on page load
    document.addEventListener('DOMContentLoaded', loadCategories);

    async function loadCategories() {
      const container = document.getElementById('categoriesTable');
      showSpinner(container);

      try {
        categories = await feedbackApi.getCategories();
        renderCategories();
      } catch (error) {
        console.error('Error loading categories:', error);
        showToast('Failed to load categories', 'error');
        container.innerHTML = '<div class="alert alert-danger">Failed to load categories.</div>';
      }
    }

    function renderCategories() {
      const container = document.getElementById('categoriesTable');

      if (categories.length === 0) {
        showEmptyState(container, 'No categories found. Create your first category!', 'tags');
        return;
      }

      container.innerHTML = `
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th style="width: 30%;">Category Name</th>
                <th style="width: 50%;">Description</th>
                <th style="width: 20%;" class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              ${categories.map(cat => `
                <tr id="row-${cat.id}" class="category-row">
                  <td>
                    <span class="view-mode">${cat.category_name}</span>
                    <input type="text" class="form-control form-control-sm edit-mode" 
                           style="display: none;" value="${cat.category_name}" 
                           id="edit-name-${cat.id}">
                  </td>
                  <td>
                    <span class="view-mode text-muted">${cat.category_description || 'No description'}</span>
                    <textarea class="form-control form-control-sm edit-mode" 
                              style="display: none;" rows="2"
                              id="edit-desc-${cat.id}">${cat.category_description || ''}</textarea>
                  </td>
                  <td class="action-buttons text-end">
                    <div class="view-mode">
                      <button class="btn btn-sm btn-outline-primary" onclick="editCategory(${cat.id})">
                        <i class="fas fa-edit"></i> Edit
                      </button>
                      <button class="btn btn-sm btn-outline-danger" onclick="deleteCategory(${cat.id}, '${cat.category_name}')">
                        <i class="fas fa-trash"></i> Delete
                      </button>
                    </div>
                    <div class="edit-mode" style="display: none;">
                      <button class="btn btn-sm btn-success" onclick="saveCategory(${cat.id})">
                        <i class="fas fa-save"></i> Save
                      </button>
                      <button class="btn btn-sm btn-secondary" onclick="cancelEdit(${cat.id})">
                        <i class="fas fa-times"></i> Cancel
                      </button>
                    </div>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;

      // Make functions available globally
      window.editCategory = (id) => {
        const row = document.getElementById(`row-${id}`);
        row.querySelectorAll('.view-mode').forEach(el => el.style.display = 'none');
        row.querySelectorAll('.edit-mode').forEach(el => el.style.display = '');
        row.classList.add('edit-mode');
      };

      window.cancelEdit = (id) => {
        const row = document.getElementById(`row-${id}`);
        row.querySelectorAll('.view-mode').forEach(el => el.style.display = '');
        row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'none');
        row.classList.remove('edit-mode');
        
        // Reset values
        const category = categories.find(c => c.id === id);
        document.getElementById(`edit-name-${id}`).value = category.category_name;
        document.getElementById(`edit-desc-${id}`).value = category.category_description || '';
      };

      window.saveCategory = async (id) => {
        const name = document.getElementById(`edit-name-${id}`).value.trim();
        const desc = document.getElementById(`edit-desc-${id}`).value.trim();

        if (!name) {
          showToast('Category name is required', 'error');
          return;
        }

        try {
          await feedbackApi.updateCategory(id, name, desc);
          showToast('Category updated successfully', 'success');
          await loadCategories();
   