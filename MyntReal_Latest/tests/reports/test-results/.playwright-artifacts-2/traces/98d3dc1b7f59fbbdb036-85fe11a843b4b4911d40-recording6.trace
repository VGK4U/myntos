      .login-subtitle {\n            margin: 0;\n            color: #495057;\n            font-size: 0.95rem;\n            font-weight: 500;\n        }\n        \n        .login-body {\n            padding: 40px;\n        }\n        \n        .form-group {\n            margin-bottom: 25px;\n        }\n        \n        .form-group label {\n            font-weight: 600;\n            color: #333;\n            margin-bottom: 8px;\n            display: block;\n        }\n        \n        .input-group {\n            position: relative;\n        }\n        \n        .input-group i.input-icon {\n            position: absolute;\n            left: 15px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: #666;\n            z-index: 10;\n        }\n        \n        .form-control {\n            padding: 12px 15px 12px 45px;\n            border-radius: 10px;\n            border: 2px solid #e0e0e0;\n            font-size: 1rem;\n            transition: all 0.3s;\n        }\n        \n        .form-control:focus {\n            border-color: var(--secondary-color);\n            box-shadow: 0 0 0 3px rgba(57, 73, 171, 0.1);\n        }\n        \n        .password-toggle {\n            position: absolute;\n            right: 15px;\n            top: 50%;\n            transform: translateY(-50%);\n            background: none;\n            border: none;\n            color: #666;\n            cursor: pointer;\n            z-index: 10;\n        }\n        \n        .btn-login {\n            width: 100%;\n            padding: 14px;\n            background: var(--primary-color);\n            border: none;\n            border-radius: 10px;\n            color: white;\n            font-size: 1.1rem;\n            font-weight: 600;\n            transition: all 0.3s;\n        }\n        \n        .btn-login:hover {\n            background: var(--secondary-color);\n            transform: translateY(-2px);\n        }\n        \n        .btn-login:disabled {\n            background: #ccc;\n            transform: none;\n        }\n        \n        .login-footer {\n            text-align: center;\n            padding: 20px 40px 30px;\n            border-top: 1px solid #eee;\n        }\n        \n        .login-footer a {\n            color: var(--secondary-color);\n            text-decoration: none;\n        }\n        \n        .login-footer a:hover {\n            text-decoration: underline;\n        }\n        \n        .alert {\n            border-radius: 10px;\n            padding: 12px 15px;\n            margin-bottom: 20px;\n        }\n        \n        .spinner-border {\n            width: 1.2rem;\n            height: 1.2rem;\n            border-width: 2px;\n        }\n        \n        /* NDA Modal Styles */\n        .nda-modal-overlay {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0, 0, 0, 0.8);\n            display: none;\n            justify-content: center;\n            align-items: center;\n            z-index: 9999;\n        }\n        \n        .nda-modal-overlay.show {\n            display: flex;\n        }\n        \n        .nda-modal {\n            background: white;\n            border-radius: 16px;\n            max-width: 900px;\n            width: 95%;\n            max-height: 90vh;\n            overflow: hidden;\n            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);\n            display: flex;\n            flex-direction: column;\n        }\n        \n        .nda-modal-header {\n            background: linear-gradient(135deg, #1a237e 0%, #3949ab 100%);\n            color: white;\n            padding: 20px 24px;\n            display: flex;\n            align-items: center;\n            gap: 16px;\n        }\n        \n        .nda-modal-header i {\n            font-size: 32px;\n        }\n        \n        .nda-modal-header h4 {\n            margin: 0;\n            font-weight: 600;\n        }\n        \n        .nda-modal-header p {\n            margin: 4px 0 0;\n            opacity: 0.9;\n            font-size: 14px;\n        }\n        \n        .nda-modal-body {\n            flex: 1;\n            overflow-y: auto;\n            padding: 24px;\n            background: #f9fafb;\n        }\n        \n        .nda-content {\n            background: white;\n            border: 1px solid #e5e7eb;\n            border-radius: 12px;\n            padding: 24px;\n            font-size: 14px;\n            line-height: 1.7;\n            color: #374151;\n        }\n        \n        .nda-content h4, .nda-content h5 {\n            color: #1f2937;\n            margin-top: 24px;\n            margin-bottom: 12px;\n        }\n        \n        .nda-content p {\n            margin-bottom: 12px;\n        }\n        \n        .nda-content ol, .nda-content ul {\n            padding-left: 24px;\n            margin-bottom: 12px;\n        }\n        \n        .nda-modal-footer {\n            padding: 20px 24px;\n            background: white;\n            border-top: 1px solid #e5e7eb;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            gap: 16px;\n        }\n        \n        .nda-warning {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            color: #92400e;\n            font-size: 13px;\n        }\n        \n        .nda-warning i {\n            color: #d97706;\n        }\n        \n        .nda-buttons {\n            display: flex;\n            gap: 12px;\n        }\n        \n        .btn-nda {\n            padding: 12px 28px;\n            border-radius: 8px;\n            font-weight: 600;\n            font-size: 14px;\n            cursor: pointer;\n            transition: all 0.2s;\n        }\n        \n        .btn-nda-cancel {\n            background: #f3f4f6;\n            color: #374151;\n            border: 1px solid #d1d5db;\n        }\n        \n        .btn-nda-cancel:hover {\n            background: #e5e7eb;\n        }\n        \n        .btn-nda-accept {\n            background: #059669;\n            color: white;\n            border: none;\n        }\n        \n        .btn-nda-accept:hover {\n            background: #047857;\n        }\n        \n        .btn-nda:disabled {\n            opacity: 0.7;\n            cursor: not-allowed;\n        }\n        \n        @media (max-width: 768px) {\n            .nda-modal {\n                width: 100%;\n                height: 100%;\n                max-height: 100%;\n                border-radius: 0;\n            }\n            \n            .nda-modal-footer {\n                flex-direction: column;\n            }\n            \n            .nda-buttons {\n                width: 100%;\n            }\n            \n            .nda-buttons button {\n                flex: 1;\n            }\n        }\n    "],"\n"],"\n",["BODY",{},"\n    ",["DIV",{"class":"login-container"},"\n        ",["DIV",{"class":"login-card"},"\n            ",["DIV",{"class":"login-header"},"\n                ",["IMG",{"__playwright_current_src__":"http://localhost:5000/assets/logos/myntreal_logo_vertical.png","src":"/assets/logos/myntreal_logo_vertical.png","alt":"MyntReal","class":"login-logo"}],"\n                ",["P",{"class":"login-subtitle"},"Employee Management System"],"\n            "],"\n            \n            ",["DIV",{"class":"login-body"},"\n                ",["DIV",{"id":"alertContainer"}],"\n                \n                ",["FORM",{"id":"loginForm"},"\n                    ",["DIV",{"class":"form-group"},"\n                        ",["LABEL",{},"Employee ID"],"\n                        ",["DIV",{"class":"input-group"},"\n                            ",["I",{"class":"fas fa-id-card input-icon"}],"\n                            ",["INPUT",{"__playwright_value_":"","type":"text","class":"form-control","id":"employeeId","placeholder":"e.g., MR10001","required":"","style":"tex