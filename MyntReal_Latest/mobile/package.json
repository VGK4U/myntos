{
  "name": "myntreal-mobile",
  "version": "1.0.0",
  "description": "MyntReal Mobile App - Staff System with Journeys",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:full": "cd ../shared/journey-core && npm install && npm run build && cd ../../mobile && tsc && vite build",
    "preview": "vite preview",
    "cap:init": "npx cap init 'MyntReal' com.myntreal.mnr --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:android": "npm run build && npx cap sync android",
    "build:ios": "npm run build && npx cap sync ios"
  },
  "keywords": [
    "mnr",
    "mobile",
    "capacitor",
    "ionic"
  ],
  "author": "MyntReal LLP",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/camera": "^6.0.2",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/clipboard": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.1",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/network": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@ionic/core": "^8.4.1",
    "@types/leaflet": "^1.9.14",
    "capacitor-native-biometric": "^4.2.2",
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-calllog": "^1.3.2",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "overrides": {
    "tar": "^6.1.11",
    "minimatch": ">=9.0.0",
    "rollup": ">=4.58.0",
    "@xmldom/xmldom": ">=0.9.0",
    "fast-xml-parser": ">=5.5.6",
    "fast-xml-builder": ">=1.0.2",
    "esbuild": ">=0.28.1",
    "postcss": ">=8.5.7",
    "brace-expansion": ">=2.0.3",
    "lodash": ">=4.18.0",
    "uuid": ">=10.0.0",
    "@tootallnate/once": ">=3.0.1"
  }
}
